# Base de datos
DATABASE_URL=postgresql://reqflow_user:reqflow_pass@localhost:5432/reqflow

# TCS AI Lab - Reemplazar con API key real antes de ejecutar
TCS_API_KEY=PLACEHOLDER_KEY_REEMPLAZAR

# Seguridad JWT
SECRET_KEY=cambiar_esto_en_produccion_usar_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# LLM Config
TCS_LLM_BASE_URL=https://genailab.tcs.in/v1/chat/completions
LLM_GENERATOR_MODEL=genailab-maas-gpt-4o
LLM_REVIEWER_MODEL=azure/genailab-maas-gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
